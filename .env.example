# OpenRouter — required for AI summaries
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional model override. The default router selects an available free model.
OPENROUTER_MODEL=openrouter/free

# Optional — get free keys at https://api.congress.gov/sign-up/
# Both fall back to DEMO_KEY when unset (rate-limited; fine for dev).
CONGRESS_API_KEY=
REGULATIONS_API_KEY=
